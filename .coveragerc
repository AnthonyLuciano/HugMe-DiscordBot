[run]
source = bot/
branch = True
omit = 
    */__init__.py
    */tests/*
    */migrations/*
    */alembic/*

[report]
exclude_lines = 
    pragma: no cover
    def __repr__
    if self.debug:
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:

show_missing = True
skip_covered = True

[html]
directory = htmlcov
